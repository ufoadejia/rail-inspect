# ===== LoongArch / 麒麟环境配置 =====
# 用法: cp .env.loongarch .env

# 多模态大模型（无 key 时自动走 mock，不影响开发演示）
DASHSCOPE_API_KEY=
QWEN_VL_MODEL=qwen-vl-max
QWEN_TEXT_MODEL=qwen-plus
USE_MOCK=true

# SQLite（默认存 backend/data/rail.db）
SQLITE_PATH=backend/data/rail.db

# CORS（前端地址）
CORS_ORIGINS=http://localhost:5173

# 应用密钥（演示用，生产环境请改）
SECRET_KEY=loongarch-demo-2026

# ===== 以下为旧配置保留，LoongArch 环境不使用 =====
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MINIO_ENDPOINT=localhost:9000
